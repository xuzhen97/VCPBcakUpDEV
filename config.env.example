# [VCPToolBox 服务端专用备份脚本配置]
# 当前 backup_vcptoolbox_only.py / restore_vcptoolbox_from_webdav.py 仅使用阿里云盘 OpenAPI

# VCPToolBox 服务端项目路径
# Linux 示例: /opt/VCPHub/VCPToolBox
# Windows 示例: D:\VCPHub\VCPToolBox
VCPToolBoxPath=D:\VCPHub\VCPToolBox

# [阿里云盘 OpenAPI 配置]
AliyunDriveEnabled=true

# 阿里云盘开放平台 appId
AliyunDriveClientId=your_app_id

# 可选：如果你的应用不是纯 Public 客户端，或平台要求带 client_secret，则填写
AliyunDriveClientSecret=

# OpenAPI 域名，一般不需要修改
AliyunDriveOpenApiBase=https://openapi.alipan.com

# Public 客户端推荐使用 oob
AliyunDriveRedirectUri=oob

# PKCE 模式：plain 或 S256。阿里云盘当前优先建议 plain 以避免 S256 兼容问题
AliyunDrivePkceMethod=plain

# 权限范围
AliyunDriveScope=user:base,file:all:read,file:all:write

# 阿里云盘中的目标目录，支持多级路径
AliyunDriveFolder=VCPToolBox备份

# 本地 token 缓存文件
AliyunDriveTokenFile=./aliyundrive_token.json

# 同名文件处理策略：auto_rename / refuse / ignore
AliyunDriveCheckNameMode=auto_rename

# 可选：如果你已经知道 drive_id，可以直接填写，留空则脚本自动获取
AliyunDriveId=

# 恢复脚本下载/解压使用的临时目录
# Linux 示例: /tmp/vcp_restore
RestoreTempDir=./restore

# 覆盖恢复模式下默认恢复到的 VCPToolBox 目录
# Linux 示例: /opt/VCPToolBox
# Windows 示例: D:\VCPHub\VCPToolBox
VCPToolBoxRestorePath=D:\VCPHub\VCPToolBox
